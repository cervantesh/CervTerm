{
  "window": {
    "initial_cols": 120,
    "initial_rows": 32,
    "decorations": "system",
    "titlebar": "dark",
    "padding": [12, 12, 0, 0],
    "opacity": 0.98,
    "text_opacity": 0.98,
    "background_opacity": 0.98
  },
  "font": {
    "family": "JetBrainsMono Nerd Font",
    "fallback": ["CaskaydiaCove Nerd Font", "Cascadia Mono", "Consolas"],
    "size": 12.5,
    "line_height": 1.08
  },
  "colors": {
    "foreground": "#FFFFFF",
    "background": "#1E1D40",
    "cursor": "#FAD000",
    "selection_background": "#B362FF"
  },
  "scrollback_lines": 10000,
  "scrollbar": {
    "mode": "always",
    "stable_gutter": true,
    "min_thumb_px": 40,
    "thumb_color": "#A599E9CC"
  },
  "tab_bar": {
    "mode": "always",
    "position": "bottom",
    "max_width_px": 220
  },
  "cursor": {
    "shape": "beam",
    "blink": false
  },
  "bell_mode": "disabled",
  "max_fps": 60
}
